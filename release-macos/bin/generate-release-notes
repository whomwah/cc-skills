#!/usr/bin/env python3
"""Generate styled HTML release notes from CHANGELOG.md for Sparkle."""

import re, sys, os

if len(sys.argv) != 4:
    print(f"Usage: {sys.argv[0]} <version> <tag> <output_dir>", file=sys.stderr)
    sys.exit(1)

version = sys.argv[1]
tag = sys.argv[2]
out_dir = sys.argv[3]

try:
    text = open("CHANGELOG.md").read()
    pattern = rf'## \[{re.escape(version)}\].*?\n(.*?)(?=\n## \[|\Z)'
    m = re.search(pattern, text, re.DOTALL)
    body_md = m.group(1).strip() if m else "Bug fixes and improvements."
except FileNotFoundError:
    body_md = "Bug fixes and improvements."


def md_to_html(md):
    lines = md.splitlines()
    html_lines = []
    in_ul = False
    for line in lines:
        if line.startswith("### "):
            if in_ul:
                html_lines.append("</ul>")
                in_ul = False
            html_lines.append(f"<h3>{line[4:].strip()}</h3>")
        elif re.match(r'^[-*] ', line):
            if not in_ul:
                html_lines.append("<ul>")
                in_ul = True
            html_lines.append(f"<li>{line[2:].strip()}</li>")
        elif line.strip() == "":
            if in_ul:
                html_lines.append("</ul>")
                in_ul = False
        else:
            if in_ul:
                html_lines.append("</ul>")
                in_ul = False
            html_lines.append(f"<p>{line.strip()}</p>")
    if in_ul:
        html_lines.append("</ul>")
    return "\n".join(html_lines)


body_html = md_to_html(body_md)

html = f"""<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <style>
    body {{
      font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
      font-size: 13px;
      line-height: 1.5;
      color: #333;
      padding: 8px 16px;
      margin: 0;
    }}
    @media (prefers-color-scheme: dark) {{
      body {{ color: #ddd; }}
    }}
    h3 {{
      font-size: 14px;
      font-weight: 600;
      margin: 12px 0 4px;
    }}
    ul {{
      margin: 4px 0 12px;
      padding-left: 20px;
    }}
    li {{
      margin: 2px 0;
    }}
  </style>
</head>
<body>
{body_html}
</body>
</html>"""

os.makedirs(out_dir, exist_ok=True)
with open(f"{out_dir}/{tag}.html", "w") as f:
    f.write(html)

print(f"Generated release notes for {version}")
